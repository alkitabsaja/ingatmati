<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="color-scheme" content="light dark">
  <title>{{ title }}{% if title %} · {% endif %}My Static Blog</title>
  {% if excerpt %}<meta name="description" content="{{ excerpt }}">{% endif %}

  {# Canonical points back to the original WordPress post/page when this
     content was synced from WP, so search engines treat WordPress as the
     authoritative source and don't flag this static mirror as duplicate
     content. Falls back to this page's own URL (e.g. the homepage, which
     has no WP equivalent). #}
  <link rel="canonical" href="{{ originalUrl or (page.url | absoluteUrl) }}">

  {# Open Graph / Twitter card tags for link previews on social platforms
     and chat apps. og:url intentionally points at *this* static site's own
     URL (not originalUrl) since that's where the share link actually goes. #}
  <meta property="og:type" content="{% if layout == 'post.njk' %}article{% else %}website{% endif %}">
  <meta property="og:title" content="{{ title }}{% if title %} · {% endif %}My Static Blog">
  <meta property="og:url" content="{{ page.url | absoluteUrl }}">
  <meta property="og:site_name" content="My Static Blog">
  {% if excerpt %}<meta property="og:description" content="{{ excerpt }}">{% endif %}
  {% if image %}<meta property="og:image" content="{{ image | absoluteUrl }}">{% endif %}
  {% if date %}<meta property="article:published_time" content="{{ date | isoDate }}">{% endif %}
  {% if author %}<meta property="article:author" content="{{ author }}">{% endif %}

  <meta name="twitter:card" content="{% if image %}summary_large_image{% else %}summary{% endif %}">
  <meta name="twitter:title" content="{{ title }}{% if title %} · {% endif %}My Static Blog">
  {% if excerpt %}<meta name="twitter:description" content="{{ excerpt }}">{% endif %}
  {% if image %}<meta name="twitter:image" content="{{ image | absoluteUrl }}">{% endif %}

  <link rel="stylesheet" href="{{ '/css/pico.min.css' | url }}">
  <link rel="stylesheet" href="{{ '/css/style.css' | url }}">

  <!--
    Set the theme before first paint to avoid a flash of the wrong theme.
    Reads a saved preference from localStorage; falls back to the visitor's
    OS-level preference (handled automatically by Pico's CSS when no
    data-theme attribute is present at all).
  -->
  <script>
    (function () {
      var saved = localStorage.getItem("theme");
      if (saved === "light" || saved === "dark") {
        document.documentElement.setAttribute("data-theme", saved);
      }
    })();
  </script>
</head>
<body>
  <header class="container site-header">
    <a class="site-title" href="{{ '/' | url }}">My Static Blog</a>
    <nav aria-label="Primary">
      <ul>
        <li><a href="{{ '/' | url }}">Home</a></li>
        {% for page in collections.pages %}
          <li><a href="{{ page.url | url }}">{{ page.data.title }}</a></li>
        {% endfor %}
        <li>
          <button id="theme-toggle" type="button" aria-label="Toggle dark and light theme" title="Toggle theme">
            <span id="theme-toggle-icon" aria-hidden="true">&#9789;</span>
          </button>
        </li>
      </ul>
    </nav>
  </header>

  <main class="container">
    {{ content | safe }}
  </main>

  <footer class="container">
    <small>mirror matikemana.com</small>
  </footer>

  <script>
    (function () {
      var root = document.documentElement;
      var toggle = document.getElementById("theme-toggle");
      var icon = document.getElementById("theme-toggle-icon");
      var mediaQuery = window.matchMedia("(prefers-color-scheme: dark)");

      function currentTheme() {
        var forced = root.getAttribute("data-theme");
        if (forced === "light" || forced === "dark") return forced;
        return mediaQuery.matches ? "dark" : "light";
      }

      function updateIcon() {
        // Sun icon when in dark mode (tap to go light), moon when in light mode (tap to go dark)
        icon.innerHTML = currentTheme() === "dark" ? "&#9728;" : "&#9789;";
      }

      toggle.addEventListener("click", function () {
        var next = currentTheme() === "dark" ? "light" : "dark";
        root.setAttribute("data-theme", next);
        localStorage.setItem("theme", next);
        updateIcon();
      });

      updateIcon();
    })();
  </script>
  <script>window.goatcounter={path:function(p){return location.host+p}}</script>
  <script data-goatcounter="https://matikemana.goatcounter.com/count"
        async src="//gc.zgo.at/count.js"></script>
</body>
</html>
